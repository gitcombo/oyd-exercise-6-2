# Terraform state files — never commit these (contain sensitive data & resource IDs)
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform lock/override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform working directories
.terraform/
.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Sensitive variable files
*.tfvars.json
# Uncomment the next line if you store secrets in terraform.tfvars
# terraform.tfvars
terraform.tfstate.backup
.terraform.lock.hcl
